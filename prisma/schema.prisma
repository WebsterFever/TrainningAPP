// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


/* =========================
   USER
========================= */

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workoutPlans   WorkoutPlan[]
  workoutSessions UserWorkoutSession[]
  exerciseProgress UserWorkoutSessionExerciseProgress[]
}

/* =========================
   WORKOUT PLAN
========================= */

model WorkoutPlan {
  id        String   @id @default(uuid())
  name      String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  workoutDays WorkoutDay[]
}

/* =========================
   WORKOUT DAY
========================= */

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model WorkoutDay {
  id                         String   @id @default(uuid())
  name                       String
  workoutPlanId              String
  isRest                     Boolean  @default(false)
  weekDay                    WeekDay
  estimatedDurationInSeconds Int
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  workoutPlan WorkoutPlan    @relation(fields: [workoutPlanId], references: [id])
  exercises   WorkoutExercise[]
  sessions    UserWorkoutSession[]
}

/* =========================
   WORKOUT EXERCISE
========================= */

model WorkoutExercise {
  id              String   @id @default(uuid())
  order           Int
  name            String
  sets            Int
  reps            Int
  restTimeSeconds Int
  workoutDayId    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workoutDay WorkoutDay @relation(fields: [workoutDayId], references: [id])
  progress   UserWorkoutSessionExerciseProgress[]
}

/* =========================
   USER WORKOUT SESSION
========================= */

model UserWorkoutSession {
  id           String   @id @default(uuid())
  userId       String
  workoutDayId String
  startedAt    DateTime @default(now())
  completedAt  DateTime?

  user       User             @relation(fields: [userId], references: [id])
  workoutDay WorkoutDay       @relation(fields: [workoutDayId], references: [id])
  progress   UserWorkoutSessionExerciseProgress[]
}

/* =========================
   EXERCISE PROGRESS
========================= */

model UserWorkoutSessionExerciseProgress {
  id               String   @id @default(uuid())
  userId           String
  workoutSessionId String
  exerciseId       String
  completedAt      DateTime?

  user           User               @relation(fields: [userId], references: [id])
  workoutSession UserWorkoutSession @relation(fields: [workoutSessionId], references: [id])
  exercise       WorkoutExercise    @relation(fields: [exerciseId], references: [id])
}